POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=appdb
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/appdb
DATABASE_URL_UNPOOLED=postgresql+psycopg2://postgres:postgres@db:5432/appdb

# URL legacy usada por código viejo (no requerida por el BFF nuevo)
BACKEND_URL=http://localhost:5000
# URL legacy usada por código viejo cuando Next corre en Docker
BACKEND_INTERNAL_URL=http://backend:5000

# BFF interno del frontend (server-only)
INTERNAL_API_BASE_URL=http://backend:5000
INTERNAL_API_KEY=

# Branding/UX pública
NEXT_PUBLIC_SITE_NAME=TCG Nexus
NEXT_PUBLIC_DEFAULT_GAME=

# Protección básica para /admin/*
ADMIN_CONSOLE_USERNAME=admin
ADMIN_CONSOLE_PASSWORD=admin

PUBLIC_API_ENABLED=false
PUBLIC_IP_RATE_LIMIT_RPM=30
