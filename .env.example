POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=appdb
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/appdb
DATABASE_URL_UNPOOLED=postgresql+psycopg2://postgres:postgres@db:5432/appdb

# URL legacy usada por código viejo (no requerida por el BFF nuevo)
BACKEND_URL=http://localhost:5000
# URL legacy usada por código viejo cuando Next corre en Docker
BACKEND_INTERNAL_URL=http://backend:5000

# BFF interno del frontend (server-only)
INTERNAL_API_BASE_URL=http://backend:5000
INTERNAL_API_KEY=

# Branding/UX pública
NEXT_PUBLIC_SITE_NAME=TCG Nexus
NEXT_PUBLIC_DEFAULT_GAME=

# Protección básica para /admin/*
ADMIN_CONSOLE_USERNAME=admin
ADMIN_CONSOLE_PASSWORD=admin

PUBLIC_API_ENABLED=false
PUBLIC_IP_RATE_LIMIT_RPM=30

# Riftbound ingest source selector: official|fallback|auto
RIFTBOUND_SOURCE=auto
# Official Riot Content API configuration (backend only).
# Expected endpoint: {RIFTBOUND_API_BASE_URL}/riftbound/content/v1/contents
# Auth: X-Riot-Token: {RIFTBOUND_API_KEY}
RIFTBOUND_API_BASE_URL=https://americas.api.riotgames.com
RIFTBOUND_API_KEY=
# Shared timeout for official/fallback HTTP clients
RIFTBOUND_TIMEOUT_SECONDS=30
# Optional fallback remote source (Riftcodex) for demo/dev
RIFTBOUND_FALLBACK_BASE_URL=

# One Piece ingest source selector: fixture|remote
ONEPIECE_SOURCE=fixture
# Punk Records remote endpoints (backend only)
ONEPIECE_PUNKRECORDS_ROOT_URL=https://raw.githubusercontent.com/DevTheFrog/punk-records/main
ONEPIECE_PUNKRECORDS_LANGUAGE=english
ONEPIECE_TIMEOUT_SECONDS=30
# Controlled fallback image used when remote records do not provide a valid image URL
ONEPIECE_IMAGE_FALLBACK_URL=https://placehold.co/367x512?text=ONE+PIECE
