POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=appdb
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/appdb

# URL usada por Next corriendo fuera de Docker (opcional, por defecto localhost:5000)
BACKEND_URL=http://localhost:5000
# URL usada por Next corriendo dentro de Docker
BACKEND_INTERNAL_URL=http://backend:5000
PUBLIC_API_ENABLED=false
PUBLIC_IP_RATE_LIMIT_RPM=30
