{
  "info": {
    "name": "API-PROJECT",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "apiKey",
      "value": ""
    }
  ],
  "auth": {
    "type": "apikey",
    "apikey": [
      {
        "key": "key",
        "value": "X-API-Key",
        "type": "string"
      },
      {
        "key": "value",
        "value": "{{apiKey}}",
        "type": "string"
      },
      {
        "key": "in",
        "value": "header",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/health"
      }
    },
    {
      "name": "games",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/games"
      }
    },
    {
      "name": "sets",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/sets?game=pokemon"
      }
    },
    {
      "name": "cards",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/cards?game=pokemon"
      }
    },
    {
      "name": "prints",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/prints?game=pokemon"
      }
    },
    {
      "name": "print detail",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/prints/1"
      }
    },
    {
      "name": "search",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/search?q=pika&game=pokemon"
      }
    },
    {
      "name": "metrics (admin)",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/admin/metrics"
      }
    },
    {
      "name": "products",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/products?game=pokemon&set_code=SV1&type=booster_box&limit=20&offset=0",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "products"
          ],
          "query": [
            {
              "key": "game",
              "value": "pokemon"
            },
            {
              "key": "set_code",
              "value": "SV1"
            },
            {
              "key": "type",
              "value": "booster_box"
            },
            {
              "key": "limit",
              "value": "20"
            },
            {
              "key": "offset",
              "value": "0"
            }
          ]
        }
      }
    },
    {
      "name": "product detail",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/products/1",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "products",
            "1"
          ]
        }
      }
    },
    {
      "name": "prices series",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/prices?entity_type=print&entity_id=1",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "prices"
          ],
          "query": [
            {
              "key": "entity_type",
              "value": "print"
            },
            {
              "key": "entity_id",
              "value": "1"
            }
          ]
        }
      }
    },
    {
      "name": "price index",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/index?set_code=SV1&source=demo&currency=EUR",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "index"
          ],
          "query": [
            {
              "key": "set_code",
              "value": "SV1"
            },
            {
              "key": "source",
              "value": "demo"
            },
            {
              "key": "currency",
              "value": "EUR"
            }
          ]
        }
      }
    }
  ]
}
